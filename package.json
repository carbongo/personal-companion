{
	"name": "personal-companion",
	"version": "0.0.1",
	"private": false,
	"description": "Self-hostable, configurable AI companion you talk to over Telegram and a built-in web chat. Local-first (Ollama) or any hosted model.",
	"license": "MIT",
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"init": "bun scripts/init.ts",
		"dev": "bun --watch src/server/index.ts",
		"start": "bun src/server/index.ts",
		"chat": "bun scripts/chat.ts",
		"db:generate": "drizzle-kit generate",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"test": "bun test"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"grammy": "^1.44.0",
		"hono": "^4.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/bun": "^1.3.14",
		"drizzle-kit": "^0.31.9",
		"typescript": "^5.7.0"
	},
	"engines": {
		"bun": ">=1.3.0"
	}
}
