# =============================================================================
# personal-companion — configuration reference
# Copy to `.env` and edit. Everything has a sensible default except secrets.
# Vars are grouped by subsystem; some land in later phases (see docs/roadmap.md).
# Nothing here should ever contain another real person's private data in a
# committed file — keep your filled-in `.env` and persona/ out of git.
# =============================================================================

# --- app ---------------------------------------------------------------------
# Display name your companion goes by, and what it calls you. These feed the
# persona; the full personality lives in your persona file (see docs/configuration.md).
COMPANION_NAME="Companion"
COMPANION_OWNER="friend"
# IANA timezone used for day-bucketing, summaries, and the date it sees.
TZ="UTC"
# Where the SQLite database and uploads are stored (mounted as a volume in Docker).
DATA_DIR="./data"
# Port for the web interface (admin + built-in chat).
PORT="8080"
# Relaunch automatically after a Settings save so the new .env applies with no
# manual step. The process simply exits and is expected to be brought back by a
# supervisor (launchd KeepAlive, Docker `restart:`, systemd `Restart=`). Leave
# "false" if nothing supervises the process, or it would just stop on save.
AUTO_RESTART_ON_SAVE="false"

# --- web interface auth ------------------------------------------------------
# The web UI is reachable to anyone who can hit the port, so protect it.
# Set a password; leave empty ONLY if the app sits behind Tailscale / a trusted proxy.
WEB_AUTH_PASSWORD=""

# --- brain (LLM provider) ----------------------------------------------------
# Provider: "ollama" (local, default) or "openai-compatible". ("anthropic" is
# planned; for now reach Anthropic models via an openai-compatible gateway.)
LLM_PROVIDER="ollama"
# Recommended local default. Pull it first: `ollama pull gemma4:12b`.
LLM_MODEL="gemma4:12b"
# Local Ollama endpoint. Default assumes Ollama runs on the same host.
LLM_OLLAMA_URL="http://localhost:11434"
# For hosted providers (openai-compatible / anthropic):
LLM_BASE_URL=""
LLM_API_KEY=""
# Generation tuning.
LLM_TEMPERATURE="0.7"
LLM_NUM_CTX="8192"
LLM_MAX_TOKENS="1000"
# Reasoning/thinking: "true" | "false" | "low" | "medium" | "high".
# Ollama honors all of these. For openai-compatible, the effort levels
# (minimal/low/medium/high) map to `reasoning_effort` on reasoning-capable models
# (OpenAI o-series/GPT-5, OpenRouter); true/false defer to the endpoint default.
LLM_THINK="true"
LLM_TIMEOUT_MS="120000"
# How many prior messages from the live day to send each turn.
LLM_HISTORY_LIMIT="60"

# --- Telegram channel (optional) ---------------------------------------------
# Create a bot with @BotFather, paste the token here. Leave empty to disable
# Telegram and use the built-in web chat only.
TELEGRAM_BOT_TOKEN=""
# Comma-separated Telegram user IDs allowed to talk to it (get yours from @userinfobot).
TELEGRAM_ALLOWED_USER_IDS=""
# Send each paragraph as its own message, like a person texting.
TELEGRAM_REPLY_SPLIT="true"
# Batch a burst of quick messages into one turn: flush after this much silence
# (idle), but never hold a batch longer than the cap (both in ms).
TELEGRAM_BATCH_IDLE_MS="2500"
TELEGRAM_BATCH_MAX_MS="15000"

# --- memory ------------------------------------------------------------------
# How many past daily summaries to keep in context, and how many saved memories.
MEMORY_CONTEXT_DAYS="7"
MEMORY_LIMIT="40"
# Nightly roll-up schedule (5-field cron, in TZ) that compresses each day into a
# summary. Driven in-process — no external cron needed. Resilient to downtime:
# any day missed while the box was off/asleep is backfilled on the next boot and
# on a periodic safety tick.
MEMORY_SUMMARY_CRON="55 23 * * *"

# --- web access (optional egress) --------------------------------------------
# Lets the companion search the web / read links via <search>/<fetch> tags.
WEB_ACCESS="true"
# Search backend: "tavily" (needs key, better) or "duckduckgo" (keyless fallback).
WEB_SEARCH_PROVIDER="duckduckgo"
TAVILY_API_KEY=""
# Max web-lookup rounds per turn, results per search, chars per fetched page.
WEB_STEPS="3"
WEB_RESULTS="5"
WEB_PAGE_CHARS="6000"
# Advanced: per-request timeouts (ms) and max concurrent lookups per round.
WEB_SEARCH_TIMEOUT_MS="12000"
WEB_FETCH_TIMEOUT_MS="12000"
WEB_MAX_REQS="3"

# --- speech-to-text (optional, for voice notes) ------------------------------
# "off" | "openai" | "whisper-http" | "local".
#   openai       — hosted Whisper API; set STT_API_KEY (+ optional STT_MODEL).
#   whisper-http — any OpenAI-compatible /audio/transcriptions endpoint; set STT_API_URL.
#   local        — whisper.cpp on this machine (no daemon, no network): set
#                  STT_LOCAL_MODEL to a ggml/gguf model file; needs `whisper-cli`
#                  and `ffmpeg` on PATH. Used by Telegram voice notes and the
#                  web chat's mic / audio upload alike.
STT_PROVIDER="off"
STT_API_URL=""
STT_API_KEY=""
STT_MODEL="whisper-1"
# Local provider:
STT_LOCAL_MODEL=""            # e.g. ./data/models/ggml-base.bin
STT_LOCAL_BIN="whisper-cli"   # whisper.cpp CLI (PATH name or absolute path)
STT_FFMPEG_BIN="ffmpeg"       # ffmpeg (PATH name or absolute path)
STT_LANGUAGE="auto"           # spoken-language hint, or "auto" to detect

# --- weather context (optional) ----------------------------------------------
# If set, the companion knows your local weather (Open-Meteo, no key needed).
WEATHER_LAT=""
WEATHER_LON=""
WEATHER_LOCATION_NAME=""
